{
  "name": "exchange_js",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main",
  "scripts": {
    "prisma:generate": "prisma generate",
    "prebuild": "npm run prisma:generate",
    "build": "nest build",
    "prestart": "npm run prisma:generate",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "prestart:dev": "npm run prisma:generate",
    "start:dev": "nest start --watch",
    "stack:up:main": "bash scripts/stack.sh up main",
    "stack:down:main": "bash scripts/stack.sh down main",
    "stack:up:all": "bash scripts/stack.sh up all",
    "stack:down:all": "bash scripts/stack.sh down all",
    "stack:status": "bash scripts/stack.sh status",
    "stack:reset:main": "bash scripts/stack.sh reset-main",
    "on:main": "bash scripts/on-stack.sh main",
    "on:stack": "bash scripts/on-stack.sh",
    "main:up": "bash scripts/stack.sh up main",
    "main:down": "bash scripts/stack.sh down main",
    "main:reset:base": "bash scripts/on-stack.sh main db:biz:reset && bash scripts/on-stack.sh main db:base:sync",
    "main:reset:biz": "bash scripts/reset-main-biz.sh",
    "main:deposit": "bash scripts/on-stack.sh main demo:deposit",
    "main:swap": "bash scripts/on-stack.sh main demo:swap",
    "main:withdraw": "bash scripts/on-stack.sh main demo:withdraw",
    "main:demo": "bash scripts/on-stack.sh main demo:all",
    "main:recon:pass": "bash scripts/on-stack.sh main recon:demo:pass",
    "main:recon:break": "bash scripts/on-stack.sh main recon:demo:break",
    "main:recon:reset": "bash scripts/on-stack.sh main recon:demo:reset",
    "db:migrate:local": "bash scripts/apply-local-migrations.sh",
    "db:base:sync": "ts-node prisma/seed.ts --mode=base",
    "db:biz:init": "ts-node prisma/seed.ts --mode=business",
    "db:seed:business": "ts-node prisma/seed.ts --mode=business && npm run verify:demo-data",
    "db:biz:reset": "ts-node scripts/reset-business-data.ts",
    "db:reset:business": "bash scripts/reset-business-complete.sh",
    "runtime:diagnose": "bash scripts/runtime-diagnose.sh",
    "governance:demo:seed": "ts-node scripts/governance-demo-seed.ts",
    "check:asset:decimals": "bash scripts/check-asset-amount-format.sh",
    "audit:retention:dry": "ts-node scripts/audit-retention-job.ts --dry-run",
    "audit:retention:apply": "ts-node scripts/audit-retention-job.ts --apply",
    "recon:demo": "DATABASE_URL=\"file:/tmp/exchange_js_main/dev.db\" TB_ADDRESS=127.0.0.1:3003 ts-node -r tsconfig-paths/register scripts/recon-demo.ts",
    "recon:demo:pass": "DATABASE_URL=\"file:/tmp/exchange_js_main/dev.db\" TB_ADDRESS=127.0.0.1:3003 ts-node -r tsconfig-paths/register scripts/recon-demo.ts --mode=pass",
    "recon:demo:break": "DATABASE_URL=\"file:/tmp/exchange_js_main/dev.db\" TB_ADDRESS=127.0.0.1:3003 ts-node -r tsconfig-paths/register scripts/recon-demo.ts --mode=break",
    "recon:demo:reset": "DATABASE_URL=\"file:/tmp/exchange_js_main/dev.db\" TB_ADDRESS=127.0.0.1:3003 ts-node -r tsconfig-paths/register scripts/recon-demo.ts --mode=reset",
    "demo:setup": "DATABASE_URL=\"file:/tmp/exchange_js_main/dev.db\" TB_ADDRESS=127.0.0.1:3003 ts-node -r tsconfig-paths/register scripts/demo-setup.ts",
    "demo:deposit": "DATABASE_URL=\"file:/tmp/exchange_js_main/dev.db\" TB_ADDRESS=127.0.0.1:3003 ts-node -r tsconfig-paths/register scripts/demo-deposit.ts",
    "demo:swap": "DATABASE_URL=\"file:/tmp/exchange_js_main/dev.db\" TB_ADDRESS=127.0.0.1:3003 ts-node -r tsconfig-paths/register scripts/demo-swap.ts",
    "demo:withdraw": "DATABASE_URL=\"file:/tmp/exchange_js_main/dev.db\" TB_ADDRESS=127.0.0.1:3003 ts-node -r tsconfig-paths/register scripts/demo-withdraw.ts",
    "demo:all": "DATABASE_URL=\"file:/tmp/exchange_js_main/dev.db\" TB_ADDRESS=127.0.0.1:3003 ts-node -r tsconfig-paths/register scripts/demo-all.ts",
    "verify:coa": "ts-node -r tsconfig-paths/register scripts/verify-realtime-coa.ts",
    "verify:demo-data": "DATABASE_URL=\"file:/tmp/exchange_js_main/dev.db\" ts-node -r tsconfig-paths/register scripts/verify-demo-data.ts",
    "prestart:debug": "npm run prisma:generate",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:setup": "bash scripts/db-setup.sh",
    "package:release": "bash scripts/package-release.sh",
    "db:seed:demo": "ts-node scripts/governance-demo-seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@nestjs/common": "^11.1.12",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.12",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.12",
    "@nestjs/platform-socket.io": "^11.1.12",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/websockets": "^11.1.12",
    "@prisma/client": "^5.22.0",
    "@types/bcrypt": "^6.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "axios": "^1.13.3",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "nestjs-pino": "^4.5.0",
    "otplib": "^13.4.0",
    "passport-jwt": "^4.0.1",
    "pino-http": "^11.0.0",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "tigerbeetle-node": "^0.17.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.5"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.12",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.10",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
