model ReconciliationRun {
  id              String   @id @default(uuid())
  runNo           String   @unique @default("TEMP")
  businessDate    String
  layer           String   // CRYPTO | FIAT
  seq             Int      @default(1)
  triggerType     String   // SCHEDULED | MANUAL | POST_FIX
  mode            String   @default("APPLY") // DRY_RUN | APPLY
  status          String   @default("RUNNING") // RUNNING | COMPLETED | FAILED
  invariantStatus String   @default("PASS")    // PASS | FAIL
  openedCount     Int      @default(0)
  reObservedCount Int      @default(0)
  closedCount     Int      @default(0)
  traceId         String?
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  demoManifest    String?  // demo-only: JSON answer-key of injected breaks (null for real/pass runs)
  cases           ReconciliationCase[] @relation("CaseOpenedByRun")
  lineItems       ReconciliationLineItem[]
  @@index([businessDate, layer])
  @@map("reconciliation_runs")
}

model ReconciliationCase {
  id                        String   @id @default(uuid())
  caseNo                    String   @unique @default("TEMP")
  businessDate              String
  assetId                   String
  assetCode                 String
  layer                     String
  book                      String?  // CLIENT | FIRM (redesign per-book case); null for legacy I1–I5 cases
  tbAmount                  Decimal  @default(0)
  inTransitAmount           Decimal  @default(0)
  expectedExternal          Decimal  @default(0)
  actualExternal            Decimal  @default(0)
  deltaAmount               Decimal  @default(0)
  status                    String   @default("OPEN") // OPEN | PENDING_RECHECK | RESOLVED
  openedByRunId             String
  closedByRunId             String?
  lastObservedRunId         String?
  slaDeadline               DateTime?
  traceId                   String?
  reimbursementObligationId String?
  // Phase B locator — pinpoints which physical wallet / COA bucket / owner this case belongs to
  // (T7 wallet-level engine fills these; legacy V8_FORMULA cases leave them null).
  walletRef                 String?
  coaCode                   String?  // 'L.CLIENT_PAYABLE+L.DEPOSIT_SUSPENSE' | 'E.FIRM_OPS' | ...
  ownerNo                   String?
  // T1 idempotency tracking — wallet-level engine reuses one case per (walletRef, businessDate)
  // across reruns. firstSeenRunId pins the run that opened it; lastUpdatedRunId moves forward each
  // rerun that re-confirms the break; resolvedAt + resolutionReason close the loop (auto-heal /
  // manual resolution / waiver); severity classifies for the cockpit. All optional — legacy
  // V8_FORMULA cases leave them null. T2 wires the upsert; T3 surfaces them via endpoints.
  firstSeenRunId            String?
  lastUpdatedRunId          String?
  resolvedAt                DateTime?
  resolutionReason          String?  // 'AUTO_HEALED' | 'MANUAL_RESOLVED' | 'WAIVED'
  severity                  String?  // 'HIGH' | 'MEDIUM' | 'LOW'
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  openedByRun               ReconciliationRun @relation("CaseOpenedByRun", fields: [openedByRunId], references: [id])
  asset                     Asset    @relation(fields: [assetId], references: [id])
  lineItems                 ReconciliationLineItem[]
  // T2: dropped @@unique([businessDate, assetId, book]) — Phase B wallet engine
  // upserts one case per (walletRef, businessDate), so multiple wallets sharing the
  // same (book, asset, date) each get their own case row. Service-layer idempotency
  // (findFirst by walletRef + status=OPEN) replaces the DB unique; a DB-level
  // partial unique (walletRef, businessDate, status=OPEN) is deferred to Phase C
  // (SQLite expression-index compatibility pending).
  @@index([businessDate, assetId, book])
  @@index([status])
  @@index([walletRef])
  @@index([walletRef, businessDate, status])
  @@map("reconciliation_cases")
}

model ReconciliationLineItem {
  id               String  @id @default(uuid())
  caseId           String
  foundByRunId     String
  lineNo           Int
  matchStatus      String  // MATCHED | ORPHAN_INTERNAL | ORPHAN_EXTERNAL | AMOUNT_MISMATCH | INVARIANT
  internalSourceType String?
  internalSourceId   String?
  internalSourceNo   String?
  internalAmount     Decimal?
  internalDirection  String?
  internalTxHash     String?
  externalSource     String?
  externalTxId       String?
  externalTxHash     String?
  externalAmount     Decimal?
  externalDirection  String?
  externalTimestamp  DateTime?
  // Phase B drill-down hooks — wallet-level engine references these to link a bucketed
  // line item back to its source (per-wallet evidence row or external statement line).
  // externalRef = bank booking id / chain tx hash (matches tb_transfer_evidence.externalRef);
  // walletRef   = which physical wallet this side belongs to.
  externalRef        String?
  walletRef          String?
  status             String  @default("OPEN")
  resolution         String?
  resolutionMemo     String?
  createdAt          DateTime @default(now())
  case               ReconciliationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  run                ReconciliationRun  @relation(fields: [foundByRunId], references: [id])
  @@index([caseId])
  @@index([externalRef])
  @@index([walletRef])
  @@map("reconciliation_line_items")
}

// 外部余额头表（每外部账户每 cutoff 一行）。对账式4/5 直接用 closing_balance，不靠明细加总。见 spec 2026-06-20 §2.1。
model ExternalBalance {
  id             String   @id @default(uuid())
  source         String   // ZAND | HEXTRUST | CHAIN
  accountRef     String   @map("account_ref") // 对账主体（法币滚到 CMA，见 §2.5）
  currency       String   // AED | USDT
  book           String   // CLIENT | FIRM（按 cutoff 快照映射）
  cutoffDate     String   @map("cutoff_date") // 业务日 D（YYYY-MM-DD）
  closingBalance Decimal  @map("closing_balance") // 核这个；Zand 取最新行 Balance
  openingBalance Decimal? @map("opening_balance") // 连续性 + roll-forward 自检
  asOfAt         DateTime? @map("as_of_at") // 外部余额精确时点（可能 ≠ cutoff）
  statementId    String?  @map("statement_id") // 关联原始对账单
  lineCount      Int?     @map("line_count")
  ingestedAt     DateTime @default(now()) @map("ingested_at")
  status         String?
  rawRef         String?  @map("raw_ref")
  // Phase B locator — which physical wallet / COA bucket this balance attests to
  // (T7 wallet-level engine matches per-wallet; legacy V8_FORMULA rows leave them null).
  walletRef      String?
  coaCode        String?
  ownerNo        String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  @@unique([source, accountRef, cutoffDate])
  @@index([cutoffDate])
  @@index([source, book, currency])
  @@index([walletRef])
  @@map("external_balances")
}

// 外部对账单归一化行表（每笔一行）。匹配键 = (account, direction, currency, external_ref)，不含金额。见 spec 2026-06-20 §2.2。
model ExternalStatementLine {
  id           String   @id @default(uuid())
  source       String   // ZAND | HEXTRUST | CHAIN
  accountRef   String   @map("account_ref") // 法币滚到 CMA（用于余额求和）
  subAccount   String?  @map("sub_account") // 原始 VirtualAccount / walletId（保留！下钻 + 充值模糊配）
  book         String   // CLIENT | FIRM
  currency     String
  direction    String   // IN | OUT（按余额增减，不用银行原始借贷）
  amount       Decimal
  externalRef  String?  @map("external_ref") // 出金=你的号(回显)；入金=空(法币)或 txHash(虚拟币)
  channelRef   String?  @map("channel_ref") // Zand ChannelRefId（出金↔退汇关联，会重复）
  datetime     DateTime // 精确入账时刻
  balanceAfter Decimal? @map("balance_after") // 行后余额（法币=主账户级）
  description  String?  // 分类（Incoming/Outgoing/Return/Intra…）
  statementId  String?  @map("statement_id")
  raw          String?  // 原始 json
  ingestedAt   DateTime @default(now()) @map("ingested_at")
  dedupKey     String   @map("dedup_key") // 内容组合键或来源 booking id（见 §2.4）
  @@unique([dedupKey])
  @@index([source, accountRef])
  @@index([datetime])
  @@index([externalRef])
  @@index([channelRef])
  @@index([subAccount])
  @@map("external_statement_lines")
}
