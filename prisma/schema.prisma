generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                @id @default(uuid())
  userNo              String                @unique @default("TEMP")
  email               String
  password            String
  // Legacy: single-role string kept for JWT backward compatibility.
  // Authoritative RBAC is resolved via userRoles → roles → role_permissions.
  // auth.service.ts includes this field in JWT roleCodes for tokens issued
  // before the roleCodes claim existed. Safe to remove only after all
  // active sessions have been refreshed.
  role                String
  status              String
  failedLoginAttempts Int                   @default(0)
  lockedUntil         DateTime?
  suspendedAt         DateTime?
  lastLoginAt         DateTime?
  deletedAt           DateTime?
  deletedBy           String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  userRoles           UserRole[]
  adminInvitations    AdminUserInvitation[]
  passwordResetTokens PasswordResetToken[]
  roleChangeRequests  AdminRoleChangeRequest[] @relation("roleChangeTarget")

  firstLoginStatus     String    @default("PENDING_IDENTITY_CONFIRM")
  mfaSecret            String?
  mfaEnabledAt         DateTime?
  mfaVerifyFailCount   Int       @default(0)
  mfaVerifyLockedUntil DateTime?
  securityAckAt        DateTime?
  firstLoginTraceId    String?

  @@index([deletedAt])
  @@map("users")
}

model Role {
  id                       String           @id @default(uuid())
  code                     String           @unique
  name                     String
  description              String?
  status                   String           @default("ACTIVE")
  approvalCaseId           String?
  approvalCaseNo           String?
  proposedPermissionGroups String?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  rolePermissions          RolePermission[]
  userRoles                UserRole[]
  modifyRequests           RoleDefinitionModifyRequest[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  code            String           @unique
  name            String
  description     String?
  method          String
  path            String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model AdminUserInvitation {
  id              String    @id @default(uuid())
  userId          String
  token           String?
  tokenHash       String    @unique
  expiresAt       DateTime
  consumedAt      DateTime?
  revokedAt       DateTime?
  createdByUserId String?
  workflowType    String?
  workflowNo      String?
  traceId         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([traceId])
  @@map("admin_user_invitations")
}

model PasswordResetToken {
  id                String    @id @default(uuid())
  resetNo           String    @unique @default("TEMP")
  userId            String
  tokenHash         String    @unique
  token             String?
  status            String    @default("PENDING")
  requestSource     String
  requestedByUserId String?
  requestedByUserNo String?
  expiresAt         DateTime
  consumedAt        DateTime?
  traceId           String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, expiresAt])
  @@index([traceId, createdAt])
  @@map("password_reset_tokens")
}

model AdminRoleChangeRequest {
  id                String    @id @default(uuid())
  requestNo         String    @unique @default("TEMP")
  targetUserId      String
  currentRoleCodes  String
  proposedRoleCodes String
  changeReason      String
  status            String    @default("PENDING_APPROVAL")
  approvalCaseId    String?
  approvalCaseNo    String?
  requestedByUserId String
  executedAt        DateTime?
  failureReason     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  targetUser        User      @relation("roleChangeTarget", fields: [targetUserId], references: [id])

  @@index([targetUserId])
  @@index([approvalCaseId])
  @@index([status])
  @@index([requestedByUserId])
  @@map("admin_role_change_requests")
}

model CustomerMain {
  // ═══ 身份 ═══
  id              String    @id @default(uuid())
  customerNo      String    @unique @default("TEMP")
  customerType    String    @default("INDIVIDUAL")
  email           String?   @unique
  phone           String?   @unique
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  firstName       String?
  lastName        String?
  companyName     String?

  // ═══ 认证 / 安全 ═══
  passwordHash      String?
  passwordUpdatedAt DateTime?
  failedLoginCount  Int       @default(0)
  lockedUntil       DateTime?
  lastLoginAt       DateTime?
  lastLoginIp       String?
  locale            String?
  timezone          String?
  termsAcceptedAt   DateTime?

  // ═══ 状态轴 1：准入旅程 ═══
  onboardingStatus  String    @default("NONE")
  onboardingTraceId String?

  // ═══ 状态轴 2：行政生命周期 ═══
  adminStatus       String    @default("INACTIVE")
  suspendedReason   String?
  suspendedAt       DateTime?

  // ═══ 状态轴 3：合规冻结 ═══
  complianceStatus           String    @default("CLEAR")
  complianceFreezeReason     String?
  complianceFreezeCaseId     String?
  complianceFreezeAt         DateTime?
  complianceFreezeReleasedAt DateTime?

  // ═══ 细粒度限制 ═══
  restrictions String @default("[]")

  // ═══ 产品属性 ═══
  investorTier          String    @default("STANDARD")
  investorTierSource    String    @default("ONBOARDING")
  investorTierUpdatedAt DateTime?

  // Trading limits (2026-05-16)
  tradingTier              String   @default("BASIC")    // BASIC | PREMIUM
  riskLevel                String   @default("LOW")      // LOW | MEDIUM | HIGH
  sumsubVerificationLevel  Int      @default(1)           // 1 | 2

  // ═══ 合规属性 ═══
  riskRating          String    @default("LOW")
  riskRatingUpdatedAt DateTime?
  eddRequired         Boolean   @default(false)
  pepStatus           String    @default("NONE")
  pepConfirmedAt      DateTime?
  cddDocumentExpiresAt DateTime?

  // ═══ Sumsub 集成 ═══
  sumsubApplicantId                  String?   @unique
  sumsubCurrentLevelName             String?
  sumsubLatestReviewId               String?
  sumsubLatestAttemptId              String?
  sumsubExperiencedLevel2            Boolean   @default(false)
  verificationProvider               String?
  verificationSubstatus              String?
  verificationCustomerActionRequired Boolean   @default(false)
  verificationCanContinue            Boolean   @default(false)
  verificationLatestEventType        String?
  verificationLatestEventAt          DateTime?

  // ═══ 工作流指针 ═══
  latestRiskApprovalId        String?   @unique
  latestRiskApprovalStatus    String?
  latestRiskAssessmentId      String?
  nextReviewAt                DateTime?

  // ═══ 时间戳 ═══
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ═══ Relations ═══
  depositTransactions       DepositTransaction[]
  swapTransactions          SwapTransaction[]
  withdrawTransactions      WithdrawTransaction[]
  payouts                   Payout[]
  payins                    Payin[]
  inboundTransferSignals    InboundTransferSignal[]
  corporateProfile          CorporateProfile?
  uboProfiles               UboProfile[]
  latestRiskApproval        ApprovalCase?            @relation("CustomerLatestRiskApproval", fields: [latestRiskApprovalId], references: [id], onDelete: SetNull)
  materialHoldings          CustomerMaterialHolding[] @relation("CustomerMaterialHoldings")
  materialRefreshCycles     MaterialRefreshCycle[]   @relation("CustomerMaterialRefreshCycles")
  riskAssessments           ClientRiskAssessment[]   @relation("CustomerRiskAssessments")
  tierUpgradeCases          TierUpgradeCase[]        @relation("CustomerTierUpgradeCases")
  withdrawalAddresses       WithdrawalAddress[]
  withdrawalFeeLevelBindings  WithdrawalFeeLevelBinding[]
  swapFeeLevelBindings        SwapFeeLevelBinding[]

  @@index([adminStatus])
  @@index([complianceStatus])
  @@index([riskRating])
  @@map("customer_main")
}

model CorporateProfile {
  id                       String   @id @default(uuid())
  customerId               String   @unique
  companyName              String
  registrationNo           String
  incorporationCountry     String
  registeredAddress        String?
  licenseType              String?
  licenseNumber            String?
  authorizedSignatoryName  String?
  authorizedSignatoryTitle String?
  documents                String? // JSON array
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  customer CustomerMain @relation(fields: [customerId], references: [id])

  @@map("corporate_profiles")
}

model UboProfile {
  id               String   @id @default(uuid())
  customerId       String
  fullName         String
  ownershipPercent Decimal?
  nationality      String?
  idNumber         String?
  pepFlag          Boolean  @default(false)
  status           String   @default("PENDING") // PENDING, CDD_IN_PROGRESS, CDD_APPROVED, EDD_IN_PROGRESS, EDD_APPROVED, REJECTED
  documents        String? // JSON array
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  customer CustomerMain @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@map("ubo_profiles")
}

model AuditLogEvent {
  id              String              @id @default(uuid())
  auditNo         String              @unique @default("TEMP")
  action          String
  entityType      String
  entityId        String?
  entityNo        String?
  traceId         String?
  workflowType    String?
  entityOwnerType String?
  entityOwnerId   String?
  actorType       String
  actorId         String
  actorNo         String?
  actorRole       String?
  requestId       String?
  sourceIp        String?
  sourcePlatform  String?
  result          String              @default("SUCCESS")
  reason          String?
  metadata        String?
  idempotencyKey  String?             @unique
  payloadDigest   String
  retainedUntil   DateTime
  entityOwnerNo   String?
  archivedAt      DateTime?
  occurredAt      DateTime            @default(now())
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  @@index([occurredAt])
  @@index([entityType, entityId])
  @@index([actorType, actorId])
  @@index([actorType, actorId, occurredAt])
  @@index([actorNo, occurredAt])
  @@index([entityOwnerNo, occurredAt])
  @@index([traceId, occurredAt])
  @@index([workflowType, occurredAt])
  @@index([result, occurredAt])
  @@index([retainedUntil])
  @@index([archivedAt])
  @@map("audit_log_events")
}

model AuditEvidencePackage {
  id                       String        @id @default(uuid())
  packageNo                String        @unique @default("TEMP")
  approvalCaseId           String?       @unique
  approvalCaseNo           String?
  exportedByType           String
  exportedById             String
  exportedByNo             String?
  exportedByRole           String?
  status                   String        @default("READY")
  exportMode               String        @default("SELECTION")
  fileName                 String?
  filterSnapshot           String?
  selectedEventIdsSnapshot String?
  itemCount                Int
  digest                   String
  manifest                 String
  packageBody              String?
  deletedAt                DateTime?
  deletedBy                String?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  approvalCase             ApprovalCase? @relation("AuditEvidencePackageApprovalCase", fields: [approvalCaseId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([exportedByType, exportedById])
  @@index([status, createdAt])
  @@index([exportMode, createdAt])
  @@index([approvalCaseId])
  @@index([approvalCaseNo])
  @@index([deletedAt])
  @@map("audit_evidence_packages")
}

model ApprovalCase {
  id                             String                         @id @default(uuid())
  approvalNo                     String                         @unique
  actionType                     String
  entityRef                      String
  createdByUserId                String
  createdByUserNo                String?
  status                         String                         @default("DRAFT")
  allowCancel                    Boolean                        @default(true)
  objectSnapshot                 String?
  traceId                        String
  createdAt                      DateTime                       @default(now())
  updatedAt                      DateTime                       @updatedAt
  submittedAt                    DateTime?
  timeoutAt                      DateTime?
  steps                          ApprovalStep[]
  evidencePackage                AuditEvidencePackage?          @relation("AuditEvidencePackageApprovalCase")
  latestForCustomerRiskApproval  CustomerMain?                  @relation("CustomerLatestRiskApproval")
  riskAssessments                ClientRiskAssessment[]         @relation("ClientRiskAssessmentApprovalCase")
  linkedRegulatoryGates          RegulatoryGateItem[]           @relation("RegulatoryGateLinkedApproval")
  internalTransactionForApproval InternalTransaction?           @relation("InternalTransactionApprovalCase")
  tierUpgradeCaseApproval        TierUpgradeCase?               @relation("TierUpgradeCaseApproval")

  @@index([actionType, entityRef, status])
  @@index([status, timeoutAt])
  @@index([traceId, createdAt])
  @@map("approval_cases")
}

model ApprovalStep {
  id                    String       @id @default(uuid())
  approvalCaseId        String
  stepNo                Int
  status                String       @default("PENDING")
  checkerRoleCandidates String
  decidedByUserId       String?
  decidedByUserNo       String?
  decidedByRole         String?
  reason                String?
  decidedAt             DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  approvalCase          ApprovalCase @relation(fields: [approvalCaseId], references: [id], onDelete: Cascade)

  @@unique([approvalCaseId, stepNo])
  @@index([approvalCaseId, stepNo])
  @@map("approval_steps")
}

model ApprovalActionPolicy {
  actionType   String   @id
  riskLevel    String   @default("HIGH")
  checkerRoles String
  stepsConfig  String?
  timeoutHours Int      @default(24)
  allowCancel  Boolean  @default(true)
  allowRetry   Boolean  @default(true)
  updatedAt    DateTime @updatedAt

  @@map("approval_action_policies")
}

model ApprovalSodRule {
  ruleCode    String   @id
  enabled     Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("approval_sod_rules")
}

model ApprovalPolicyChangeRequest {
  id                   String    @id @default(uuid())
  requestNo            String    @unique @default("TEMP")
  targetActionType     String
  currentCheckerRoles  String
  proposedCheckerRoles String
  currentStepsConfig   String?
  proposedStepsConfig  String?
  changeReason         String
  status               String    @default("PENDING_APPROVAL")
  approvalCaseId       String?
  approvalCaseNo       String?
  requestedByUserId    String
  executedAt           DateTime?
  failureReason        String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  @@index([targetActionType, status])
  @@index([approvalCaseId])
  @@index([status])
  @@index([requestedByUserId])
  @@map("approval_policy_change_requests")
}

model ShareholdingRegistryVersion {
  id                   String                            @id @default(uuid())
  registryNo           String                            @unique @default("TEMP")
  status               String                            @default("DRAFT")
  versionLabel         String?
  effectiveFrom        DateTime?
  effectiveTo          DateTime?
  supersededById       String?
  latestApprovalId     String?
  latestApprovalStatus String?
  docRef               String?
  evidenceRef          String?
  metadataJson         String                            @default("{}")
  traceId              String
  createdByUserId      String
  updatedByUserId      String?
  createdAt            DateTime                          @default(now())
  updatedAt            DateTime                          @updatedAt
  participants         ShareholdingRegistryParticipant[]
  regulatoryGates      RegulatoryGateItem[]              @relation("RegulatoryGateShareholdingVersion")

  @@index([status, createdAt])
  @@index([registryNo, createdAt])
  @@index([traceId, createdAt])
  @@index([latestApprovalStatus, createdAt])
  @@map("shareholding_registry_versions")
}

model ShareholdingRegistryParticipant {
  id               String                      @id @default(uuid())
  versionId        String
  participantType  String
  participantName  String
  ownershipPercent Decimal?
  controlSummary   String?
  evidenceRef      String?
  metadataJson     String                      @default("{}")
  sortOrder        Int                         @default(0)
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  version          ShareholdingRegistryVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId, sortOrder])
  @@index([participantType, createdAt])
  @@map("shareholding_registry_participants")
}

model AppointmentRecord {
  id                   String               @id @default(uuid())
  appointmentNo        String               @unique @default("TEMP")
  status               String               @default("PLANNED")
  roleType             String
  personName           String
  regulatedFlag        Boolean              @default(false)
  proposedEffectiveAt  DateTime?
  effectiveAt          DateTime?
  endedAt              DateTime?
  latestApprovalId     String?
  latestApprovalStatus String?
  docRef               String?
  evidenceRef          String?
  metadataJson         String               @default("{}")
  traceId              String
  createdByUserId      String
  updatedByUserId      String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  regulatoryGates      RegulatoryGateItem[] @relation("RegulatoryGateAppointmentRecord")

  @@index([status, createdAt])
  @@index([appointmentNo, createdAt])
  @@index([traceId, createdAt])
  @@index([latestApprovalStatus, createdAt])
  @@map("appointment_records")
}

model TrainingRecord {
  id              String    @id @default(uuid())
  trainingNo      String    @unique @default("TEMP")
  status          String    @default("ASSIGNED")
  assignee        String
  trainingType    String
  dueAt           DateTime?
  completedAt     DateTime?
  waiverReason    String?
  evidenceRef     String?
  metadataJson    String    @default("{}")
  traceId         String
  createdByUserId String
  updatedByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([trainingNo, createdAt])
  @@index([dueAt, status])
  @@index([traceId, createdAt])
  @@map("training_records")
}

model ConflictDisclosure {
  id                String    @id @default(uuid())
  disclosureNo      String    @unique @default("TEMP")
  status            String    @default("OPEN")
  disclosureType    String
  disclosedByName   String
  disclosedAt       DateTime
  reviewDueAt       DateTime?
  mitigationSummary String?
  closedAt          DateTime?
  evidenceRef       String?
  metadataJson      String    @default("{}")
  traceId           String
  createdByUserId   String
  updatedByUserId   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([disclosureNo, createdAt])
  @@index([reviewDueAt, status])
  @@index([traceId, createdAt])
  @@map("conflict_disclosures")
}

model WindDownMaterialRecord {
  id              String    @id @default(uuid())
  materialNo      String    @unique @default("TEMP")
  status          String    @default("ACTIVE")
  materialType    String
  versionLabel    String
  effectiveAt     DateTime?
  reviewDueAt     DateTime?
  supersededAt    DateTime?
  supersededById  String?
  evidenceRef     String?
  metadataJson    String    @default("{}")
  traceId         String
  createdByUserId String
  updatedByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([materialNo, createdAt])
  @@index([reviewDueAt, status])
  @@index([traceId, createdAt])
  @@map("wind_down_material_records")
}

model RegulatoryGateItem {
  id                            String                       @id @default(uuid())
  gateNo                        String                       @unique @default("TEMP")
  gateType                      String
  authority                     String                       @default("VARA")
  subjectType                   String
  subjectId                     String
  subjectNo                     String
  scopeSummary                  String?
  shareholdingRegistryVersionId String?
  appointmentRecordId           String?
  walletId                      String?
  linkedApprovalId              String?
  internalApprovalStatus        String                       @default("NOT_REQUIRED")
  filingStatus                  String                       @default("REQUIRED")
  receiptStatus                 String                       @default("PENDING")
  effectivenessStatus           String                       @default("BLOCKED")
  gateResult                    String                       @default("BLOCKED")
  filingRefNo                   String?
  filingSubmittedAt             DateTime?
  latestFeedback                String?
  latestFeedbackAt              DateTime?
  receiptType                   String?
  receiptRefNo                  String?
  receiptBoundAt                DateTime?
  proposedEffectiveAt           DateTime?
  effectiveAt                   DateTime?
  revokedAt                     DateTime?
  metadataJson                  String                       @default("{}")
  traceId                       String
  activeKey                     String?                      @unique
  createdByUserId               String
  updatedByUserId               String?
  createdAt                     DateTime                     @default(now())
  updatedAt                     DateTime                     @updatedAt
  shareholdingRegistryVersion   ShareholdingRegistryVersion? @relation("RegulatoryGateShareholdingVersion", fields: [shareholdingRegistryVersionId], references: [id], onDelete: SetNull)
  appointmentRecord             AppointmentRecord?           @relation("RegulatoryGateAppointmentRecord", fields: [appointmentRecordId], references: [id], onDelete: SetNull)
  wallet                        Wallet?                      @relation("RegulatoryGateWallet", fields: [walletId], references: [id], onDelete: SetNull)
  linkedApproval                ApprovalCase?                @relation("RegulatoryGateLinkedApproval", fields: [linkedApprovalId], references: [id], onDelete: SetNull)

  @@index([gateType, createdAt])
  @@index([subjectType, subjectId, createdAt])
  @@index([subjectType, subjectNo, createdAt])
  @@index([gateResult, createdAt])
  @@index([filingStatus, receiptStatus, effectivenessStatus])
  @@index([traceId, createdAt])
  @@map("regulatory_gate_items")
}



model LiquidityProvider {
  id             String                   @id
  name           String
  email          String?                  @unique
  phone          String?
  status         String                   @default("INACTIVE")
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")
  configurations LiquidityConfiguration[]

  @@index([name])
  @@index([status])
  @@map("liquidity_provider")
}

model Asset {
  id                             String                          @id @default(uuid())
  assetNo                        String?                         @unique
  type                           String
  currency                       String
  code                           String                          @unique
  network                        String?
  decimals                       Int
  description                    String?
  status                         String                          @default("ACTIVE")
  tbLedgerId                     Int?                            @unique
  contractAddress                String?
  minDepositAmount               Float?
  maxDepositAmount               Float?
  minWithdrawAmount              Float?
  maxWithdrawAmount              Float?
  depositEnabled                 Boolean                         @default(true)
  withdrawalEnabled              Boolean                         @default(true)
  suspendedAt                    DateTime?
  suspendReason                  String?
  preSuspendDepositEnabled       Boolean?
  preSuspendWithdrawalEnabled    Boolean?
  approvalCaseId                 String?
  approvalCaseNo                 String?
  createdAt                      DateTime                        @default(now())
  updatedAt                      DateTime                        @updatedAt
  depositTransactions            DepositTransaction[]
  fromConfigs                    LiquidityConfiguration[]        @relation("FromAsset")
  toConfigs                      LiquidityConfiguration[]        @relation("ToAsset")
  feeConfigs                     LiquidityConfiguration[]        @relation("FeeAsset")
  payins                         Payin[]
  inboundTransferSignals         InboundTransferSignal[]
  payouts                        Payout[]
  swapFromTransactions           SwapTransaction[]               @relation("SwapFromAsset")
  swapToTransactions             SwapTransaction[]               @relation("SwapToAsset")
  swapQuoteFroms                 SwapQuote[]                     @relation("SwapQuoteFromAsset")
  swapQuoteTos                   SwapQuote[]                     @relation("SwapQuoteToAsset")
  withdrawPricingQuotes          WithdrawPricingQuote[]
  outstandings                   Outstanding[]
  feeAccruals                    FeeAccrual[]
  wallets                        Wallet[]
  withdrawTransactions           WithdrawTransaction[]
  internalTransactions           InternalTransaction[]
  internalFunds                  InternalFund[]
  reconciliationCases            ReconciliationCase[]
  withdrawalAddresses            WithdrawalAddress[]
  withdrawalFeeLevels            WithdrawalFeeLevel[]
  swapFeeLevelsFrom              SwapFeeLevel[]                  @relation("SwapFeeLevelFromAsset")
  swapFeeLevelsTo                SwapFeeLevel[]                  @relation("SwapFeeLevelToAsset")

  @@unique([type, currency, network])
  @@map("assets")
}

model Payin {
  id                     String                  @id @default(uuid())
  payinNo                String                  @unique @default("TEMP")
  depositId              String?
  type                   String                  @default("crypto")
  status                 String
  toWalletId             String?
  assetId                String
  amount                 Decimal
  toAddress              String?
  toIban                 String?
  fromWalletId           String?
  fromAddress            String?
  fromIban               String?
  txHash                 String?
  confirmations          Int                     @default(0)
  referenceNo            String?
  providerTxnId          String?
  receivedAt             DateTime?
